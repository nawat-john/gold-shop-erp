// Prisma schema — source of truth ของโครงสร้าง DB
// กติกา (ADR-002): เงิน = BIGINT สตางค์, น้ำหนัก = NUMERIC(10,3) กรัม
// ตารางธุรกรรมห้าม soft delete — ใช้ status + reversal เท่านั้น

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// เลขที่เอกสารแบบ no-gap (บิล/ใบกำกับภาษี/สัญญา)
/// จองเลขภายใน transaction เดียวกับการสร้างเอกสารเสมอ — ถ้า tx rollback เลขถูกคืนอัตโนมัติ
/// ห้าม query ตารางนี้ตรง ๆ — ใช้ผ่าน documentNumberService เท่านั้น
model DocumentSequence {
  /// เช่น "TAXINV-BKK01-2569" (ประเภทเอกสาร-สาขา-ปี)
  key        String   @id
  nextNumber BigInt   @default(1) @map("next_number")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("document_sequences")
}

// ───────────────────────── Phase 1: Auth, RBAC, Audit, Settings ─────────────────────────

/// สาขา — master data ใช้ soft delete ผ่าน isActive
model Branch {
  id        String   @id @default(uuid())
  code      String   @unique // เช่น "HQ", "BKK01" — ใช้ประกอบเลขที่เอกสาร
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userBranchRoles UserBranchRole[]

  @@map("branches")
}

model User {
  id                  String    @id @default(uuid())
  username            String    @unique
  passwordHash        String    @map("password_hash") // Argon2id
  displayName         String    @map("display_name")
  email               String?
  isActive            Boolean   @default(true) @map("is_active")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  /// TOTP secret เข้ารหัส AES-256-GCM — ห้ามเก็บ plaintext
  totpSecretEnc       String?   @map("totp_secret_enc")
  totpEnabled         Boolean   @default(false) @map("totp_enabled")
  /// PIN อนุมัติ (step-up) — Argon2id, แยกจากรหัสผ่าน login
  approvalPinHash     String?   @map("approval_pin_hash")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  sessions        Session[]
  userBranchRoles UserBranchRole[]
  recoveryCodes   RecoveryCode[]

  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  code        String  @unique // "OWNER", "BRANCH_MANAGER", "CASHIER", ...
  name        String
  description String?
  /// role ระบบ (จาก seed) ห้ามลบ/แก้ code
  isSystem    Boolean @default(false) @map("is_system")

  rolePermissions RolePermission[]
  userBranchRoles UserBranchRole[]

  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique // เช่น "user.manage", "sale.void" — deny-by-default
  description String

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// สิทธิ์ผู้ใช้ผูกกับสาขา — user คนเดียวมีได้หลาย role หลายสาขา
model UserBranchRole {
  userId   String @map("user_id")
  branchId String @map("branch_id")
  roleId   String @map("role_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, branchId, roleId])
  @@map("user_branch_roles")
}

/// Session ฝั่ง server — cookie เก็บ token ดิบ, DB เก็บเฉพาะ SHA-256 hash
model Session {
  id                String    @id @default(uuid())
  tokenHash         String    @unique @map("token_hash")
  userId            String    @map("user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  lastSeenAt        DateTime  @default(now()) @map("last_seen_at")
  absoluteExpiresAt DateTime  @map("absolute_expires_at")
  revokedAt         DateTime? @map("revoked_at")
  ip                String?
  userAgent         String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// รหัสกู้คืน 2FA — เก็บเป็น HMAC hash ใช้ได้ครั้งเดียว
model RecoveryCode {
  id       String    @id @default(uuid())
  userId   String    @map("user_id")
  codeHash String    @map("code_hash")
  usedAt   DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("recovery_codes")
}

/// Audit log — append-only บังคับด้วย Postgres trigger (ห้าม UPDATE/DELETE)
/// ไม่มี FK ไป users โดยเจตนา: log ต้องอยู่รอดอิสระจากทุกตาราง
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  requestId  String?  @map("request_id")
  /// null = การกระทำโดยระบบ (job/seed)
  actorId    String?  @map("actor_id")
  action     String // เช่น "user.create", "auth.login_failed"
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  branchId   String?  @map("branch_id")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

/// การตั้งค่าระบบแบบ key-value (เรตรับซื้อ, threshold, timeout ฯลฯ)
model Setting {
  key         String   @id
  value       Json
  description String?
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
