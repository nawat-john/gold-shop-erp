// Prisma schema — source of truth ของโครงสร้าง DB
// กติกา (ADR-002): เงิน = BIGINT สตางค์, น้ำหนัก = NUMERIC(10,3) กรัม
// ตารางธุรกรรมห้าม soft delete — ใช้ status + reversal เท่านั้น

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// เลขที่เอกสารแบบ no-gap (บิล/ใบกำกับภาษี/สัญญา)
/// จองเลขภายใน transaction เดียวกับการสร้างเอกสารเสมอ — ถ้า tx rollback เลขถูกคืนอัตโนมัติ
/// ห้าม query ตารางนี้ตรง ๆ — ใช้ผ่าน documentNumberService เท่านั้น
model DocumentSequence {
  /// เช่น "TAXINV-BKK01-2569" (ประเภทเอกสาร-สาขา-ปี)
  key        String   @id
  nextNumber BigInt   @default(1) @map("next_number")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("document_sequences")
}

// ───────────────────────── Phase 1: Auth, RBAC, Audit, Settings ─────────────────────────

/// สาขา — master data ใช้ soft delete ผ่าน isActive
model Branch {
  id        String   @id @default(uuid())
  code      String   @unique // เช่น "HQ", "BKK01" — ใช้ประกอบเลขที่เอกสาร
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userBranchRoles  UserBranchRole[]
  storageLocations StorageLocation[]
  inventoryItems   InventoryItem[]
  stockMovements   StockMovement[]
  transfersOut     BranchTransfer[]  @relation("TransferFrom")
  transfersIn      BranchTransfer[]  @relation("TransferTo")
  cashTransfersOut CashTransfer[]    @relation("CashTransferFrom")
  cashTransfersIn  CashTransfer[]    @relation("CashTransferTo")
  meltLots         MeltLot[]
  stockCounts      StockCount[]
  cashDrawers      CashDrawer[]
  pawnContracts    PawnContract[]
  savingsAccounts  SavingsAccount[]
  workOrders       WorkOrder[]
  expenses         Expense[]
  journalEntries   JournalEntry[]

  @@map("branches")
}

model User {
  id                  String    @id @default(uuid())
  username            String    @unique
  passwordHash        String    @map("password_hash") // Argon2id
  displayName         String    @map("display_name")
  email               String?
  isActive            Boolean   @default(true) @map("is_active")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  /// TOTP secret เข้ารหัส AES-256-GCM — ห้ามเก็บ plaintext
  totpSecretEnc       String?   @map("totp_secret_enc")
  totpEnabled         Boolean   @default(false) @map("totp_enabled")
  /// PIN อนุมัติ (step-up) — Argon2id, แยกจากรหัสผ่าน login
  approvalPinHash     String?   @map("approval_pin_hash")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  sessions        Session[]
  userBranchRoles UserBranchRole[]
  recoveryCodes   RecoveryCode[]
  commissions     Commission[]

  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  code        String  @unique // "OWNER", "BRANCH_MANAGER", "CASHIER", ...
  name        String
  description String?
  /// role ระบบ (จาก seed) ห้ามลบ/แก้ code
  isSystem    Boolean @default(false) @map("is_system")

  rolePermissions RolePermission[]
  userBranchRoles UserBranchRole[]

  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique // เช่น "user.manage", "sale.void" — deny-by-default
  description String

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// สิทธิ์ผู้ใช้ผูกกับสาขา — user คนเดียวมีได้หลาย role หลายสาขา
model UserBranchRole {
  userId   String @map("user_id")
  branchId String @map("branch_id")
  roleId   String @map("role_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, branchId, roleId])
  @@map("user_branch_roles")
}

/// Session ฝั่ง server — cookie เก็บ token ดิบ, DB เก็บเฉพาะ SHA-256 hash
model Session {
  id                String    @id @default(uuid())
  tokenHash         String    @unique @map("token_hash")
  userId            String    @map("user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  lastSeenAt        DateTime  @default(now()) @map("last_seen_at")
  absoluteExpiresAt DateTime  @map("absolute_expires_at")
  revokedAt         DateTime? @map("revoked_at")
  ip                String?
  userAgent         String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// รหัสกู้คืน 2FA — เก็บเป็น HMAC hash ใช้ได้ครั้งเดียว
model RecoveryCode {
  id       String    @id @default(uuid())
  userId   String    @map("user_id")
  codeHash String    @map("code_hash")
  usedAt   DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("recovery_codes")
}

/// Audit log — append-only บังคับด้วย Postgres trigger (ห้าม UPDATE/DELETE)
/// ไม่มี FK ไป users โดยเจตนา: log ต้องอยู่รอดอิสระจากทุกตาราง
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  requestId  String?  @map("request_id")
  /// null = การกระทำโดยระบบ (job/seed)
  actorId    String?  @map("actor_id")
  action     String // เช่น "user.create", "auth.login_failed"
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  branchId   String?  @map("branch_id")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([branchId, createdAt])
  @@map("audit_logs")
}

/// การตั้งค่าระบบแบบ key-value (เรตรับซื้อ, threshold, timeout ฯลฯ)
model Setting {
  key         String   @id
  value       Json
  description String?
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ───────────────────────── Phase 2: Gold Price Engine ─────────────────────────

/// ราคาจาก feed ภายนอก (สมาคมค้าทองคำ) — ทุกประกาศเก็บหมด ไม่ทับของเก่า
/// ราคาทั้งหมด: BIGINT สตางค์ ต่อ 1 บาททอง (ADR-002)
model GoldPriceFeed {
  id           String   @id @default(uuid())
  /// "GTA" = สมาคมค้าทองคำ, "MANUAL" = กรอกมือเมื่อ feed ล่ม
  source       String
  /// เวลาประกาศของต้นทาง — คู่กับ source กันบันทึกประกาศเดิมซ้ำ
  announcedAt  DateTime @map("announced_at")
  fetchedAt    DateTime @default(now()) @map("fetched_at")
  barBuy       BigInt   @map("bar_buy")
  barSell      BigInt   @map("bar_sell")
  ornamentBuy  BigInt   @map("ornament_buy")
  ornamentSell BigInt   @map("ornament_sell")
  /// payload ดิบจากต้นทาง — ไว้ debug/audit
  raw          Json?

  announcements ShopPriceAnnouncement[]

  @@unique([source, announcedAt])
  @@index([announcedAt])
  @@map("gold_price_feeds")
}

/// ราคาประกาศหน้าร้าน (ราคากลางจาก HQ ใช้ทุกสาขา) — บิลทุกใบอ้างราคาจากตารางนี้
/// แถวล่าสุด (announcedAt มากสุด) = ราคาปัจจุบัน; ห้ามแก้/ลบ ประกาศใหม่ทับเท่านั้น
model ShopPriceAnnouncement {
  id            String   @id @default(uuid())
  announcedAt   DateTime @default(now()) @map("announced_at")
  barBuy        BigInt   @map("bar_buy")
  barSell       BigInt   @map("bar_sell")
  ornamentBuy   BigInt   @map("ornament_buy")
  ornamentSell  BigInt   @map("ornament_sell")
  /// feed ที่ใช้อ้างอิงตอนประกาศ (null = ประกาศมือล้วน)
  basedOnFeedId String?  @map("based_on_feed_id")
  /// ผู้ประกาศ — ต้องมี permission price.announce
  announcedBy   String   @map("announced_by")
  note          String?

  basedOnFeed GoldPriceFeed? @relation(fields: [basedOnFeedId], references: [id])

  @@index([announcedAt])
  @@map("shop_price_announcements")
}

// ───────────────────────── Phase 3: Inventory ─────────────────────────
// กติกาสำคัญ:
// - สินค้ารายชิ้น (SERIALIZED เช่น ทองรูปพรรณ) = 1 แถว inventory_items ต่อชิ้น, serialNo ไม่ซ้ำ
// - สินค้านับจำนวน (COUNTED เช่น ทองแท่งมาตรฐาน) ไม่มีแถวรายชิ้น — ยอดคงเหลือ derive จาก ledger
// - stock_movements เป็น ledger แบบ append-only (มี trigger กัน UPDATE/DELETE เหมือน audit_logs)
//   ยอดคงเหลือทุกชนิดต้อง replay จาก ledger แล้วตรงกับสถานะรายชิ้นเสมอ (invariant job Phase 8)

/// ผู้ขายส่ง/โรงงาน — master data
model Supplier {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  phone     String?
  address   String?
  note      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inventoryItems InventoryItem[]

  @@map("suppliers")
}

/// หมวดสินค้า (สร้อยคอ/แหวน/กำไล/ทองแท่ง...) + ค่ากำเหน็จ default ของหมวด
model ProductCategory {
  id                 String   @id @default(uuid())
  code               String   @unique
  name               String
  /// ค่ากำเหน็จ default สตางค์/ชิ้น (override ได้ที่ product และรายชิ้น)
  defaultLaborCharge BigInt?  @map("default_labor_charge")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("product_categories")
}

/// วิธีติดตามสต๊อกของสินค้า
enum ProductTracking {
  /// รายชิ้น — ทองรูปพรรณทุกชิ้นมีป้ายเลขไม่ซ้ำ
  SERIALIZED
  /// นับจำนวน — ทองแท่งมาตรฐานน้ำหนักตายตัว
  COUNTED
}

/// แบบสินค้า (SKU) — ชิ้นจริงอยู่ที่ inventory_items
model Product {
  id          String          @id @default(uuid())
  sku         String          @unique
  name        String
  categoryId  String          @map("category_id")
  tracking    ProductTracking
  /// % ความบริสุทธิ์ เช่น 96.50 (ค่า default ของแบบ — ชิ้นจริง override ได้)
  goldPurity  Decimal         @map("gold_purity") @db.Decimal(5, 2)
  /// น้ำหนักมาตรฐาน มก./หน่วย (จำเป็นสำหรับ COUNTED; SERIALIZED ใช้น้ำหนักชั่งจริงรายชิ้น)
  stdWeightMg BigInt?         @map("std_weight_mg")
  /// ค่ากำเหน็จ default สตางค์/ชิ้น (override ค่าหมวด)
  laborCharge BigInt?         @map("labor_charge")
  /// ลาย เช่น "สร้อยลายผ่าหวาย"
  pattern     String?
  photoPath   String?         @map("photo_path")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  category           ProductCategory     @relation(fields: [categoryId], references: [id])
  inventoryItems     InventoryItem[]
  stockMovements     StockMovement[]
  salesOrderItems    SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([categoryId])
  @@map("products")
}

/// ตำแหน่งจัดเก็บในสาขา: ตู้โชว์/ถาด/เซฟ
enum StorageKind {
  SHOWCASE
  TRAY
  SAFE
  OTHER
}

model StorageLocation {
  id        String      @id @default(uuid())
  branchId  String      @map("branch_id")
  code      String
  name      String
  kind      StorageKind @default(SHOWCASE)
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  branch         Branch          @relation(fields: [branchId], references: [id])
  inventoryItems InventoryItem[]
  pawnContracts  PawnContract[]

  @@unique([branchId, code])
  @@map("storage_locations")
}

/// สถานะชิ้นทอง — state machine (transition ถูกบังคับที่ service layer + ledger)
enum ItemStatus {
  IN_STOCK
  /// ถูกดึงเข้าบิลที่ยังไม่จ่ายเงิน (กันสองเครื่องขายชิ้นเดียวกัน)
  RESERVED
  SOLD
  PAWNED_COLLATERAL
  IN_TRANSIT
  MELTED
  MISSING
}

/// ที่มาของชิ้นทอง
enum AcquisitionSource {
  /// รับใหม่จาก supplier/โรงงาน
  SUPPLIER
  /// รับซื้อทองเก่าหน้าร้าน (Phase 4)
  BUYBACK
  /// ทองหลุดขายฝาก (Phase 5)
  PAWN_FORFEIT
}

/// ชิ้นทองจริง (เฉพาะสินค้า SERIALIZED)
model InventoryItem {
  id          String            @id @default(uuid())
  /// เลขป้ายทอง — ไม่ซ้ำทั้งระบบ ใช้พิมพ์ barcode/QR
  serialNo    String            @unique @map("serial_no")
  productId   String            @map("product_id")
  branchId    String            @map("branch_id")
  status      ItemStatus        @default(IN_STOCK)
  /// น้ำหนักชั่งจริง มก.
  weightMg    BigInt            @map("weight_mg")
  goldPurity  Decimal           @map("gold_purity") @db.Decimal(5, 2)
  /// ต้นทุน สตางค์ (ทองหลุด = เงินต้นค้าง; รับซื้อ = ราคาที่จ่ายจริง)
  costSatang  BigInt            @map("cost_satang")
  /// ค่ากำเหน็จขาย สตางค์ (override product/category)
  laborCharge BigInt?           @map("labor_charge")
  source      AcquisitionSource @default(SUPPLIER)
  supplierId  String?           @map("supplier_id")
  locationId  String?           @map("location_id")
  photoPath   String?           @map("photo_path")
  receivedAt  DateTime          @default(now()) @map("received_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  product            Product              @relation(fields: [productId], references: [id])
  branch             Branch               @relation(fields: [branchId], references: [id])
  supplier           Supplier?            @relation(fields: [supplierId], references: [id])
  location           StorageLocation?     @relation(fields: [locationId], references: [id])
  labels             ProductLabel[]
  stockMovements     StockMovement[]
  transferItems      BranchTransferItem[]
  meltLotItems       MeltLotItem[]
  countItems         StockCountItem[]
  salesOrderItems    SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([branchId, status])
  @@index([productId])
  @@map("inventory_items")
}

/// ประวัติพิมพ์ป้ายทอง — พิมพ์ซ้ำได้ ทุกครั้งมีบันทึก (ป้ายจริงใช้ serialNo ของชิ้น)
model ProductLabel {
  id        String   @id @default(uuid())
  itemId    String   @map("item_id")
  printedBy String   @map("printed_by")
  printedAt DateTime @default(now()) @map("printed_at")
  /// เหตุผลพิมพ์ซ้ำ (ป้ายหลุด/ชำรุด) — null = พิมพ์ครั้งแรก
  reason    String?

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@map("product_labels")
}

/// ประเภทการเคลื่อนไหวสต๊อก
enum StockMovementType {
  RECEIVE_SUPPLIER
  BUYBACK_IN
  PAWN_FORFEIT_IN
  SALE_OUT
  TRANSFER_OUT
  TRANSFER_IN
  MELT_OUT
  COUNT_ADJUST_IN
  COUNT_ADJUST_OUT
  MANUAL_ADJUST_IN
  MANUAL_ADJUST_OUT
}

/// Ledger การเคลื่อนไหวสต๊อก — append-only (DB trigger กัน UPDATE/DELETE/TRUNCATE)
/// SERIALIZED: quantity = ±1 + itemId; COUNTED: quantity = ±n, itemId = null
model StockMovement {
  id           BigInt            @id @default(autoincrement())
  movementType StockMovementType @map("movement_type")
  branchId     String            @map("branch_id")
  productId    String            @map("product_id")
  itemId       String?           @map("item_id")
  /// +รับเข้า / -ตัดออก (ห้ามเป็น 0 — CHECK ระดับ DB)
  quantity     Int
  /// น้ำหนักรวมของการเคลื่อนไหว มก. (เครื่องหมายเดียวกับ quantity)
  weightMg     BigInt            @map("weight_mg")
  /// ต้นทุนของการเคลื่อนไหว สตางค์ (ถ้ามี)
  costSatang   BigInt?           @map("cost_satang")
  /// เอกสารอ้างอิง เช่น ("branch_transfer", id) / ("stock_count", id)
  refType      String?           @map("ref_type")
  refId        String?           @map("ref_id")
  actorId      String            @map("actor_id")
  requestId    String?           @map("request_id")
  note         String?
  createdAt    DateTime          @default(now()) @map("created_at")

  branch  Branch         @relation(fields: [branchId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  item    InventoryItem? @relation(fields: [itemId], references: [id])

  @@index([branchId, productId, createdAt])
  @@index([itemId])
  @@index([refType, refId])
  @@map("stock_movements")
}

/// โอนย้ายระหว่างสาขา — 2-step confirm (ส่งยืนยัน → รับยืนยัน)
enum TransferStatus {
  DRAFT
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model BranchTransfer {
  id           String         @id @default(uuid())
  /// เลขที่เอกสาร จาก document_sequences
  docNo        String         @unique @map("doc_no")
  fromBranchId String         @map("from_branch_id")
  toBranchId   String         @map("to_branch_id")
  status       TransferStatus @default(DRAFT)
  createdBy    String         @map("created_by")
  sentBy       String?        @map("sent_by")
  sentAt       DateTime?      @map("sent_at")
  receivedBy   String?        @map("received_by")
  receivedAt   DateTime?      @map("received_at")
  note         String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  fromBranch Branch               @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch               @relation("TransferTo", fields: [toBranchId], references: [id])
  items      BranchTransferItem[]

  @@index([fromBranchId, status])
  @@index([toBranchId, status])
  @@map("branch_transfers")
}

model BranchTransferItem {
  transferId String @map("transfer_id")
  itemId     String @map("item_id")

  transfer BranchTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item     InventoryItem  @relation(fields: [itemId], references: [id])

  @@id([transferId, itemId])
  @@map("branch_transfer_items")
}

/// โอนเงินสดระหว่างสาขา — 2-step confirm เหมือน BranchTransfer (ของ) แต่ไม่ลง GL:
/// ผังบัญชีมีบัญชี "เงินสด" ใบเดียวรวมทุกสาขา ย้ายเงินระหว่างลิ้นชักไม่กระทบเงินสดรวมของบริษัท
/// (ดู postJournalEntry — หนึ่ง entry ผูกกับหนึ่งสาขาเท่านั้น จึงลงบัญชีข้ามสาขาไม่ได้อยู่แล้ว)
model CashTransfer {
  id            String         @id @default(uuid())
  /// เลขที่เอกสาร จาก document_sequences
  docNo         String         @unique @map("doc_no")
  fromBranchId  String         @map("from_branch_id")
  toBranchId    String         @map("to_branch_id")
  /// ลิ้นชักต้นทาง/ปลายทาง — เว้นว่างได้ถ้าเป็นเงินจากตู้เซฟ/ที่ไม่ผูกกับลิ้นชักขาย
  fromDrawerId  String?        @map("from_drawer_id")
  toDrawerId    String?        @map("to_drawer_id")
  amountSatang  BigInt         @map("amount_satang")
  status        TransferStatus @default(DRAFT)
  createdBy     String         @map("created_by")
  sentBy        String?        @map("sent_by")
  sentAt        DateTime?      @map("sent_at")
  receivedBy    String?        @map("received_by")
  receivedAt    DateTime?      @map("received_at")
  note          String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  fromBranch Branch      @relation("CashTransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch      @relation("CashTransferTo", fields: [toBranchId], references: [id])
  fromDrawer CashDrawer? @relation("CashDrawerTransferFrom", fields: [fromDrawerId], references: [id])
  toDrawer   CashDrawer? @relation("CashDrawerTransferTo", fields: [toDrawerId], references: [id])

  @@index([fromBranchId, status])
  @@index([toBranchId, status])
  @@map("cash_transfers")
}

/// รอบส่งหลอม/คืนโรงงาน — รวมทองเก่า ชั่งน้ำหนักส่ง-รับ ดูผลต่าง
enum MeltLotStatus {
  OPEN
  SENT
  CLOSED
  CANCELLED
}

model MeltLot {
  id               String        @id @default(uuid())
  docNo            String        @unique @map("doc_no")
  branchId         String        @map("branch_id")
  status           MeltLotStatus @default(OPEN)
  /// น้ำหนักรวมตอนส่ง มก. (ชั่งจริงตอนปิดรอบส่ง)
  sentWeightMg     BigInt?       @map("sent_weight_mg")
  /// น้ำหนัก/มูลค่าที่ได้รับคืนจากโรงงาน
  returnedWeightMg BigInt?       @map("returned_weight_mg")
  returnedSatang   BigInt?       @map("returned_satang")
  createdBy        String        @map("created_by")
  sentAt           DateTime?     @map("sent_at")
  closedAt         DateTime?     @map("closed_at")
  note             String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  branch Branch        @relation(fields: [branchId], references: [id])
  items  MeltLotItem[]

  @@index([branchId, status])
  @@map("melt_lots")
}

model MeltLotItem {
  lotId  String @map("lot_id")
  itemId String @map("item_id")

  lot  MeltLot       @relation(fields: [lotId], references: [id], onDelete: Cascade)
  item InventoryItem @relation(fields: [itemId], references: [id])

  @@id([lotId, itemId])
  @@map("melt_lot_items")
}

/// รอบตรวจนับสต๊อก — ปรับปรุงผลต่างต้องผ่านอนุมัติ (step-up PIN)
enum StockCountStatus {
  OPEN
  REVIEW
  APPROVED
  CANCELLED
}

model StockCount {
  id         String           @id @default(uuid())
  docNo      String           @unique @map("doc_no")
  branchId   String           @map("branch_id")
  status     StockCountStatus @default(OPEN)
  createdBy  String           @map("created_by")
  approvedBy String?          @map("approved_by")
  startedAt  DateTime         @default(now()) @map("started_at")
  closedAt   DateTime?        @map("closed_at")
  note       String?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  branch Branch           @relation(fields: [branchId], references: [id])
  items  StockCountItem[]

  @@index([branchId, status])
  @@map("stock_counts")
}

/// ผลนับรายชิ้น: expected จาก DB ณ เวลาเปิดรอบ, counted จากการสแกนจริง
model StockCountItem {
  countId   String    @map("count_id")
  itemId    String    @map("item_id")
  /// สถานะที่ระบบคาดไว้ตอนเปิดรอบ
  expected  Boolean   @default(true)
  /// สแกนพบจริงไหม (null = ยังไม่ได้นับ)
  found     Boolean?
  countedBy String?   @map("counted_by")
  countedAt DateTime? @map("counted_at")

  count StockCount    @relation(fields: [countId], references: [id], onDelete: Cascade)
  item  InventoryItem @relation(fields: [itemId], references: [id])

  @@id([countId, itemId])
  @@map("stock_count_items")
}

// ───────────────────────── Phase 4: POS & Payments & Tax ─────────────────────────

enum ShiftStatus {
  OPEN
  CLOSED
  RECONCILED
}

model CashDrawer {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  code      String // เช่น "DRAWER-01"
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch Branch  @relation(fields: [branchId], references: [id])
  shifts Shift[]
  cashTransfersOut CashTransfer[] @relation("CashDrawerTransferFrom")
  cashTransfersIn  CashTransfer[] @relation("CashDrawerTransferTo")

  @@unique([branchId, code])
  @@map("cash_drawers")
}

model Shift {
  id                 String      @id @default(uuid())
  branchId           String      @map("branch_id")
  drawerId           String      @map("drawer_id")
  openedById         String      @map("opened_by_id")
  openedAt           DateTime    @default(now()) @map("opened_at")
  closedById         String?     @map("closed_by_id")
  closedAt           DateTime?   @map("closed_at")
  startCashSatang    BigInt      @map("start_cash_satang")
  endCashSatang      BigInt?     @map("end_cash_satang")
  expectedCashSatang BigInt?     @map("expected_cash_satang")
  reconciledAt       DateTime?   @map("reconciled_at")
  reconciledById     String?     @map("reconciled_by_id")
  status             ShiftStatus @default(OPEN)

  drawer         CashDrawer      @relation(fields: [drawerId], references: [id])
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]

  @@map("shifts")
}

enum SalesOrderStatus {
  PENDING
  COMPLETED
  VOIDED
}

model SalesOrder {
  id                String           @id @default(uuid())
  docNo             String           @unique @map("doc_no") // จาก document_sequences
  branchId          String           @map("branch_id")
  shiftId           String           @map("shift_id")
  /// ลูกค้าที่ลงทะเบียน CRM (Phase 6) — null = ลูกค้าจร ไม่ผูกโปรไฟล์
  customerId        String?          @map("customer_id")
  priceSnapshot     Json             @map("price_snapshot") // snapshot ราคาทอง
  totalAmountSatang BigInt           @map("total_amount_satang")
  vatAmountSatang   BigInt           @map("vat_amount_satang")
  status            SalesOrderStatus @default(COMPLETED)
  idempotencyKey    String?          @unique @map("idempotency_key")
  voidedAt          DateTime?        @map("voided_at")
  voidedById        String?          @map("voided_by_id")
  voidReason        String?          @map("void_reason")
  createdBy         String           @map("created_by")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  shift       Shift            @relation(fields: [shiftId], references: [id])
  customer    Customer?        @relation(fields: [customerId], references: [id])
  items       SalesOrderItem[]
  payments    Payment[]
  tradeIn     TradeIn?
  taxInvoices TaxInvoice[]
  commission  Commission?

  @@map("sales_orders")
}

model SalesOrderItem {
  id                String  @id @default(uuid())
  orderId           String  @map("order_id")
  productId         String  @map("product_id")
  itemId            String? @map("item_id") // null สำหรับ COUNTED
  quantity          Int
  weightMg          BigInt  @map("weight_mg")
  goldPurity        Decimal @map("gold_purity") @db.Decimal(5, 2)
  goldPriceSatang   BigInt  @map("gold_price_satang")
  laborChargeSatang BigInt  @map("labor_charge_satang")
  vatAmountSatang   BigInt  @map("vat_amount_satang")
  totalAmountSatang BigInt  @map("total_amount_satang")

  order   SalesOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  item    InventoryItem? @relation(fields: [itemId], references: [id])

  @@map("sales_order_items")
}

enum PurchaseOrderStatus {
  COMPLETED
  VOIDED
}

model PurchaseOrder {
  id                String              @id @default(uuid())
  docNo             String              @unique @map("doc_no")
  branchId          String              @map("branch_id")
  shiftId           String              @map("shift_id")
  /// ลูกค้าที่ลงทะเบียน CRM (Phase 6) — null = ลูกค้าจร ไม่ผูกโปรไฟล์
  customerId        String?             @map("customer_id")
  priceSnapshot     Json                @map("price_snapshot")
  totalAmountSatang BigInt              @map("total_amount_satang")
  status            PurchaseOrderStatus @default(COMPLETED)
  customerName      String?             @map("customer_name")
  customerPhone     String?             @map("customer_phone")
  customerCitizenId String?             @map("customer_citizen_id") // เลขบัตร ปชช. เข้ารหัส
  idempotencyKey    String?             @unique @map("idempotency_key")
  voidedAt          DateTime?           @map("voided_at")
  voidedById        String?             @map("voided_by_id")
  voidReason        String?             @map("void_reason")
  createdBy         String              @map("created_by")
  createdAt         DateTime            @default(now()) @map("created_at")

  shift    Shift               @relation(fields: [shiftId], references: [id])
  customer Customer?           @relation(fields: [customerId], references: [id])
  items    PurchaseOrderItem[]
  payments Payment[]
  tradeIn  TradeIn?

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String  @id @default(uuid())
  orderId           String  @map("order_id")
  productId         String? @map("product_id") // null หากเป็นเศษทองชำรุดไม่มี SKU
  itemId            String? @map("item_id") // ชิ้นที่สร้างในคลัง (status = IN_STOCK, source = BUYBACK)
  description       String // เช่น "สร้อยคอขาด"
  weightMg          BigInt  @map("weight_mg")
  goldPurity        Decimal @map("gold_purity") @db.Decimal(5, 2)
  unitPriceSatang   BigInt  @map("unit_price_satang")
  totalAmountSatang BigInt  @map("total_amount_satang")

  order   PurchaseOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [id])
  item    InventoryItem? @relation(fields: [itemId], references: [id])

  @@map("purchase_order_items")
}

model TradeIn {
  id              String   @id @default(uuid())
  docNo           String   @unique @map("doc_no")
  salesOrderId    String   @unique @map("sales_order_id")
  purchaseOrderId String   @unique @map("purchase_order_id")
  netAmountSatang BigInt   @map("net_amount_satang") // ยอดสุทธิ (+ ลูกค้าจ่ายเพิ่ม / - ร้านจ่ายคืน)
  createdAt       DateTime @default(now()) @map("created_at")

  salesOrder    SalesOrder    @relation(fields: [salesOrderId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  payments      Payment[]

  @@map("trade_ins")
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT_CARD
}

model Payment {
  id              String        @id @default(uuid())
  salesOrderId    String?       @map("sales_order_id")
  purchaseOrderId String?       @map("purchase_order_id")
  tradeInId       String?       @map("trade_in_id")
  paymentMethod   PaymentMethod @map("payment_method")
  amountSatang    BigInt        @map("amount_satang")
  feeSatang       BigInt        @default(0) @map("fee_satang") // ค่าธรรมเนียมบัตรเครดิต
  referenceNo     String?       @map("reference_no") // เลขที่ธุรกรรม/เลขอ้างอิงโอน
  slipPath        String?       @map("slip_path") // ที่อยู่ไฟล์รูปหลักฐานโอน
  createdAt       DateTime      @default(now()) @map("created_at")

  salesOrder    SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  tradeIn       TradeIn?       @relation(fields: [tradeInId], references: [id])

  @@map("payments")
}

model TaxInvoice {
  id              String   @id @default(uuid())
  docNo           String   @unique @map("doc_no")
  salesOrderId    String   @map("sales_order_id")
  customerName    String   @map("customer_name")
  customerAddress String?  @map("customer_address")
  customerTaxId   String?  @map("customer_tax_id")
  isFull          Boolean  @default(false) @map("is_full") // true = เต็มรูป, false = อย่างย่อ
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])

  @@map("tax_invoices")
}

// ───────────────────────── Phase 5: Pawn (ขายฝากทอง) ─────────────────────────
// กติกาสำคัญ:
// - สัญญาไม่สร้าง inventory_items ระหว่างสถานะ ACTIVE (ทองยังเป็นของลูกค้า ไม่ใช่สต๊อกร้าน)
//   ทรัพย์ค้ำประกันเก็บรายละเอียดไว้ในตัว pawn_contracts เอง + location อ้าง storage_locations
// - เมื่อทองหลุด (FORFEITED) เท่านั้นที่สร้าง inventory_items จริง (source=PAWN_FORFEIT,
//   costSatang=เงินต้นค้าง) พร้อม stock_movements (PAWN_FORFEIT_IN) — reuse enum ที่ประกาศไว้ตั้งแต่ Phase 3
// - pawn_events เป็น ledger แบบ append-only (เหมือน stock_movements/audit_logs) บันทึกทุก transition
// - pawn_interest_payments แยกจาก pawn_events เพื่อให้ Phase 7 (บัญชี) query รายได้ดอกเบี้ยได้ตรงๆ

enum PawnContractStatus {
  ACTIVE
  REDEEMED
  FORFEITED
  CANCELLED
}

enum PawnEventType {
  OPEN
  RENEW_INTEREST
  REDEEM
  FORFEIT
  PRINCIPAL_INCREASE
  PRINCIPAL_DECREASE
  CANCEL
}

model PawnContract {
  id       String             @id @default(uuid())
  /// เลขที่สัญญา จาก document_sequences เช่น "PWN-BKK01-2569-000001"
  docNo    String             @unique @map("doc_no")
  branchId String             @map("branch_id")
  status   PawnContractStatus @default(ACTIVE)

  /// ลูกค้าที่ลงทะเบียน CRM (Phase 6) — null = ลูกค้าจร ไม่ผูกโปรไฟล์ (field ด้านล่างยังใช้ได้เป็น fallback)
  customerId            String? @map("customer_id")
  customerName          String  @map("customer_name")
  customerPhone         String? @map("customer_phone")
  /// เลขบัตร ปชช. เข้ารหัส AES-256-GCM (กติกาสถาปัตยกรรมข้อ 9)
  customerCitizenIdEnc  String? @map("customer_citizen_id_enc")
  /// HMAC hash สำหรับค้นหาเลขบัตรที่เข้ารหัสแล้ว
  customerCitizenIdHash String? @map("customer_citizen_id_hash")

  /// รายละเอียดทรัพย์ที่ขายฝาก (ไม่ผูก SKU เพราะเป็นของลูกค้าเอง)
  description       String
  weightMg          BigInt  @map("weight_mg")
  goldPurity        Decimal @map("gold_purity") @db.Decimal(5, 2)
  photoPath         String? @map("photo_path")
  customerPhotoPath String? @map("customer_photo_path")
  locationId        String? @map("location_id")

  /// เงินต้น (สินไถ่เริ่มต้น) — ปรับได้ผ่าน adjustPrincipal
  principalSatang           BigInt  @map("principal_satang")
  /// อัตราดอกเบี้ยตกลง %/ปี — ต้องไม่เกินเพดานกฎหมาย (settings)
  annualInterestRatePercent Decimal @map("annual_interest_rate_percent") @db.Decimal(5, 2)
  /// ระยะเวลาไถ่ถอนตามสัญญา (เดือน) — ใช้คำนวณ due date เริ่มต้น/ต่อดอก
  termMonths                Int     @map("term_months")

  startDate               DateTime @default(now()) @map("start_date")
  /// วันครบกำหนดไถ่ถอนปัจจุบัน — เลื่อนออกไปทุกครั้งที่ต่อดอก
  dueDate                 DateTime @map("due_date")
  /// ดอกเบี้ยชำระแล้วถึงวันที่นี้ — คำนวณดอกเบี้ยค้างครั้งถัดไปเริ่มนับจากวันนี้
  interestPaidThroughDate DateTime @map("interest_paid_through_date")

  redeemedAt    DateTime? @map("redeemed_at")
  redeemedById  String?   @map("redeemed_by_id")
  forfeitedAt   DateTime? @map("forfeited_at")
  forfeitedById String?   @map("forfeited_by_id")
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledById String?   @map("cancelled_by_id")
  cancelReason  String?   @map("cancel_reason")

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch           Branch                @relation(fields: [branchId], references: [id])
  customer         Customer?             @relation(fields: [customerId], references: [id])
  location         StorageLocation?      @relation(fields: [locationId], references: [id])
  events           PawnEvent[]
  interestPayments PawnInterestPayment[]

  @@index([branchId, status])
  @@index([status, dueDate])
  @@map("pawn_contracts")
}

/// Ledger เหตุการณ์สัญญาขายฝาก — append-only (DB trigger กัน UPDATE/DELETE/TRUNCATE)
model PawnEvent {
  id                    BigInt        @id @default(autoincrement())
  contractId            String        @map("contract_id")
  eventType             PawnEventType @map("event_type")
  principalBeforeSatang BigInt        @map("principal_before_satang")
  principalAfterSatang  BigInt        @map("principal_after_satang")
  /// ดอกเบี้ยที่ชำระ/คำนวณในเหตุการณ์นี้ (RENEW_INTEREST, REDEEM)
  interestAmountSatang  BigInt?       @map("interest_amount_satang")
  periodFrom            DateTime?     @map("period_from")
  periodTo              DateTime?     @map("period_to")
  actorId               String        @map("actor_id")
  requestId             String?       @map("request_id")
  note                  String?
  createdAt             DateTime      @default(now()) @map("created_at")

  contract PawnContract @relation(fields: [contractId], references: [id])

  @@index([contractId, createdAt])
  @@map("pawn_events")
}

/// ประวัติรับชำระดอกเบี้ย — แยกจาก pawn_events เพื่อให้บัญชี (Phase 7) query รายได้ดอกเบี้ยตรงๆ
model PawnInterestPayment {
  id                   String   @id @default(uuid())
  contractId           String   @map("contract_id")
  periodFrom           DateTime @map("period_from")
  periodTo             DateTime @map("period_to")
  interestAmountSatang BigInt   @map("interest_amount_satang")
  principalAfterSatang BigInt   @map("principal_after_satang")
  paidAt               DateTime @default(now()) @map("paid_at")
  actorId              String   @map("actor_id")
  requestId            String?  @map("request_id")

  contract PawnContract @relation(fields: [contractId], references: [id])

  @@index([contractId, paidAt])
  @@map("pawn_interest_payments")
}

// ───────────────────────── Phase 6: Savings, Work Orders, CRM, AMLO ─────────────────────────
// กติกาสำคัญ:
// - Customer เป็นจุดศูนย์กลาง CRM — SalesOrder/PurchaseOrder/PawnContract/SavingsAccount/WorkOrder
//   ผูก customerId แบบ optional (ลูกค้าจรยังทำธุรกรรมได้โดยไม่ต้องลงทะเบียน)
// - savings_transactions และ work_order_events เป็น ledger แบบ append-only เหมือน pawn_events
// - AMLO: เกินเพดานเงินสด (settings) ต้องมี customerId + citizenId ก่อนทำรายการสำเร็จ (บังคับ KYC)

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
}

/// โปรไฟล์ลูกค้า CRM — ศูนย์กลางประวัติธุรกรรมทุกโมดูล
model Customer {
  id   String @id @default(uuid())
  /// รหัสลูกค้า จาก document_sequences เช่น "CUS-000001"
  code String @unique

  name    String
  phone   String?
  address String?
  note    String?

  /// เลขบัตร ปชช. เข้ารหัส AES-256-GCM (KYC/AMLO) — ล้างค่าเมื่อ anonymize (PDPA)
  citizenIdEnc  String? @map("citizen_id_enc")
  /// HMAC hash — ใช้ค้นหา/กันลงทะเบียนซ้ำ และเทียบกับ AMLO watchlist
  citizenIdHash String? @unique @map("citizen_id_hash")

  loyaltyPoints Int          @default(0) @map("loyalty_points")
  tier          CustomerTier @default(BRONZE)

  /// PDPA: ยินยอมเก็บ/ใช้ข้อมูลส่วนบุคคล
  consentGivenAt     DateTime? @map("consent_given_at")
  consentWithdrawnAt DateTime? @map("consent_withdrawn_at")
  /// ไม่ null แปลว่าโปรไฟล์นี้ถูกล้างข้อมูลส่วนตัวแล้ว (สิทธิ์ถูกลืม) — แถวยังอยู่เพื่อคง FK ประวัติธุรกรรม
  anonymizedAt       DateTime? @map("anonymized_at")

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesOrders     SalesOrder[]
  purchaseOrders  PurchaseOrder[]
  pawnContracts   PawnContract[]
  savingsAccounts SavingsAccount[]
  workOrders      WorkOrder[]
  amloAlerts      AmloAlert[]

  @@map("customers")
}

enum AmloAlertStatus {
  PENDING
  REVIEWED
  REPORTED
}

/// อ้างอิงประเภทเอกสารที่ทริกเกอร์ AMLO
enum AmloRefType {
  SALES_ORDER
  PURCHASE_ORDER
  PAWN_CONTRACT
}

/// แจ้งเตือนธุรกรรมเข้าเกณฑ์ AMLO (เงินสดเกินเพดาน) — สร้างอัตโนมัติ ต้องมีเจ้าหน้าที่ตรวจทาน/รายงาน
model AmloAlert {
  id             String          @id @default(uuid())
  customerId     String?         @map("customer_id")
  refType        AmloRefType     @map("ref_type")
  refId          String          @map("ref_id")
  amountSatang   BigInt          @map("amount_satang")
  /// ตรงกับ AMLO watchlist ตอนตรวจสอบหรือไม่
  watchlistMatch Boolean         @default(false) @map("watchlist_match")
  status         AmloAlertStatus @default(PENDING)
  reviewedById   String?         @map("reviewed_by_id")
  reviewedAt     DateTime?       @map("reviewed_at")
  reportedAt     DateTime?       @map("reported_at")
  note           String?
  createdAt      DateTime        @default(now()) @map("created_at")

  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([status])
  @@index([refType, refId])
  @@map("amlo_alerts")
}

/// ทะเบียนรายชื่อเฝ้าระวัง AMLO — เทียบด้วย HMAC hash ของเลขบัตร ปชช. เท่านั้น
model AmloWatchlistEntry {
  id            String   @id @default(uuid())
  citizenIdHash String   @unique @map("citizen_id_hash")
  name          String
  reason        String
  addedBy       String   @map("added_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("amlo_watchlist_entries")
}

enum SavingsAccountType {
  /// ออมเงิน — ฝากเป็นเงินสด แปลงเป็นน้ำหนักทองตอนปิดบัญชีด้วยราคา ณ วันปิด
  CASH_SAVINGS
  /// ออมน้ำหนัก — แปลงเป็นน้ำหนักทองทันทีทุกครั้งที่ฝากด้วยราคา ณ วันฝาก
  WEIGHT_SAVINGS
}

enum SavingsAccountStatus {
  ACTIVE
  /// ปิดบัญชีรับทอง (ครบเป้า/ลูกค้าขอรับทอง)
  CLOSED_GOLD
  /// ปิดบัญชีรับเงินคืน (ยกเลิกกลางคัน)
  CLOSED_CASH
  /// ปิดบัญชีเพราะลูกค้าผิดนัดไม่ฝากตามกำหนดต่อเนื่อง
  CLOSED_DEFAULTED
}

enum SavingsTxType {
  OPEN
  DEPOSIT
  CLOSE_GOLD
  CLOSE_CASH
  CLOSE_DEFAULTED
}

model SavingsAccount {
  id          String               @id @default(uuid())
  /// เลขที่บัญชี จาก document_sequences เช่น "SAV-BKK01-2569-000001"
  docNo       String               @unique @map("doc_no")
  branchId    String               @map("branch_id")
  customerId  String?              @map("customer_id")
  accountType SavingsAccountType   @map("account_type")
  status      SavingsAccountStatus @default(ACTIVE)

  /// ยอดสะสมเงินสด สตางค์ (เฉพาะ CASH_SAVINGS)
  balanceSatang   BigInt  @default(0) @map("balance_satang")
  /// ยอดสะสมน้ำหนักทอง มก. (เฉพาะ WEIGHT_SAVINGS)
  balanceWeightMg BigInt  @default(0) @map("balance_weight_mg")
  /// เป้าหมายน้ำหนักทอง มก. (ถ้ามีกำหนดเป้า)
  targetWeightMg  BigInt? @map("target_weight_mg")

  openedAt   DateTime  @default(now()) @map("opened_at")
  closedAt   DateTime? @map("closed_at")
  closedById String?   @map("closed_by_id")

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch       Branch               @relation(fields: [branchId], references: [id])
  customer     Customer?            @relation(fields: [customerId], references: [id])
  transactions SavingsTransaction[]

  @@index([branchId, status])
  @@map("savings_accounts")
}

/// Ledger ธุรกรรมออมทอง — append-only (DB trigger กัน UPDATE/DELETE/TRUNCATE)
model SavingsTransaction {
  id            BigInt        @id @default(autoincrement())
  accountId     String        @map("account_id")
  txType        SavingsTxType @map("tx_type")
  amountSatang  BigInt?       @map("amount_satang")
  weightMg      BigInt?       @map("weight_mg")
  /// snapshot ราคาตอนทำรายการ (format เดียวกับ price-snapshot.service) — ใช้แปลงเงิน<->น้ำหนัก
  priceSnapshot Json?         @map("price_snapshot")
  actorId       String        @map("actor_id")
  requestId     String?       @map("request_id")
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")

  account SavingsAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
  @@map("savings_transactions")
}

enum WorkOrderType {
  /// สั่งทำ — เบิกทองช่างไปขึ้นรูป
  CUSTOM_ORDER
  /// ซ่อม — รับของลูกค้ามาซ่อม
  REPAIR
}

enum WorkOrderStatus {
  RECEIVED
  IN_PROGRESS
  COMPLETED
  DELIVERED
  CANCELLED
}

enum WorkOrderEventType {
  RECEIVE
  GOLD_ISSUE
  STATUS_CHANGE
  COMPLETE
  DELIVER
  CANCEL
}

model WorkOrder {
  id          String          @id @default(uuid())
  docNo       String          @unique @map("doc_no")
  branchId    String          @map("branch_id")
  customerId  String?         @map("customer_id")
  type        WorkOrderType
  status      WorkOrderStatus @default(RECEIVED)
  description String

  /// เงินมัดจำ สตางค์
  depositSatang    BigInt @default(0) @map("deposit_satang")
  /// เบิกทองช่าง มก. (เฉพาะ CUSTOM_ORDER)
  goldIssuedMg     BigInt @default(0) @map("gold_issued_mg")
  /// ค่าเผื่อเศษทองที่ยอมรับได้ มก.
  toleranceMg      BigInt @default(0) @map("tolerance_mg")
  /// ค่าบริการซ่อม สตางค์ (เฉพาะ REPAIR)
  serviceFeeSatang BigInt @default(0) @map("service_fee_satang")

  receivedAt  DateTime  @default(now()) @map("received_at")
  promisedAt  DateTime? @map("promised_at")
  completedAt DateTime? @map("completed_at")
  deliveredAt DateTime? @map("delivered_at")
  cancelledAt DateTime? @map("cancelled_at")

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch   Branch           @relation(fields: [branchId], references: [id])
  customer Customer?        @relation(fields: [customerId], references: [id])
  events   WorkOrderEvent[]

  @@index([branchId, status])
  @@map("work_orders")
}

/// Ledger เหตุการณ์งานช่าง — append-only (DB trigger กัน UPDATE/DELETE/TRUNCATE)
model WorkOrderEvent {
  id          BigInt             @id @default(autoincrement())
  workOrderId String             @map("work_order_id")
  eventType   WorkOrderEventType @map("event_type")
  note        String?
  actorId     String             @map("actor_id")
  requestId   String?            @map("request_id")
  createdAt   DateTime           @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId, createdAt])
  @@map("work_order_events")
}

// ───────────────────────── Phase 7: Accounting, Finance, Reports ─────────────────────────
// กติกาสำคัญ:
// - ทุกธุรกรรมจาก Phase 4-6 ต้องมี posting rule ลง journal_entries/journal_lines (double-entry)
// - journal_lines เป็น append-only (เหมือน pawn_events) — แก้ไขด้วยการกลับรายการ (reversal) เท่านั้น
// - Σdebit = Σcredit ต่อ 1 journal_entry บังคับด้วย DEFERRABLE CONSTRAINT TRIGGER (เช็คตอน COMMIT)
// - accounting_periods ปิดงวดแล้ว (LOCKED) ต้องปฏิเสธการโพสต์ธุรกรรมย้อนหลังทั้งระบบ
// - นโยบายบัญชีบางจุดถูกทำให้ง่ายลงโดยเจตนา (ดูคอมเมนต์ใน accounting.service.ts/posting-rules.ts)
//   ควรให้นักบัญชี/ที่ปรึกษาร้านทองรีวิวก่อนใช้งานจริง (ตามความเสี่ยงที่ระบุไว้ในแผน §9)

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

/// ผังบัญชี (Chart of Accounts) — seed มาตรฐานผ่าน accounting-seed.ts, ห้ามลบบัญชีระบบ
model Account {
  id       String      @id @default(uuid())
  code     String      @unique
  name     String
  type     AccountType
  isSystem Boolean     @default(true) @map("is_system")
  isActive Boolean     @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  journalLines JournalLine[]
  expenses     Expense[]

  @@map("accounts")
}

enum AccountingPeriodStatus {
  OPEN
  LOCKED
}

/// งวดบัญชีรายเดือน — ปิดงวด (LOCKED) แล้วห้ามโพสต์ธุรกรรมวันที่อยู่ในงวดนั้นอีก
model AccountingPeriod {
  id         String                 @id @default(uuid())
  /// เช่น "2569-04" (ปี พ.ศ.-เดือน) — สร้างอัตโนมัติเมื่อมีธุรกรรมแรกของเดือนนั้น
  yearMonth  String                 @unique @map("year_month")
  status     AccountingPeriodStatus @default(OPEN)
  lockedAt   DateTime?              @map("locked_at")
  lockedById String?                @map("locked_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  journalEntries JournalEntry[]
  commissions    Commission[]

  @@map("accounting_periods")
}

/// ใบสำคัญบัญชี (Journal Entry) — หนึ่งเอกสารต่อหนึ่งเหตุการณ์ทางบัญชี
model JournalEntry {
  id          String   @id @default(uuid())
  /// เลขที่ใบสำคัญ จาก document_sequences เช่น "JE-2569-000001"
  entryNo     String   @unique @map("entry_no")
  periodId    String   @map("period_id")
  /// สาขาต้นทางของธุรกรรม — หนึ่ง entry ผูกกับหนึ่งสาขาเสมอ (ธุรกรรมข้ามสาขา เช่น โอนเงินสด ไม่ลง GL เพราะไม่กระทบเงินสดรวม)
  branchId    String   @map("branch_id")
  entryDate   DateTime @map("entry_date")
  description String
  /// อ้างอิงเอกสารต้นทาง เช่น ("sales_order", id) — unique กันโพสต์ซ้ำ/ใช้ทำ backfill แบบ idempotent
  refType     String?  @map("ref_type")
  refId       String?  @map("ref_id")
  /// true = รายการบันทึกมือ (ค่าใช้จ่าย/ปรับปรุง) ไม่ใช่ auto-post จากธุรกรรม
  isManual    Boolean  @default(false) @map("is_manual")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  period  AccountingPeriod @relation(fields: [periodId], references: [id])
  branch  Branch           @relation(fields: [branchId], references: [id])
  lines   JournalLine[]
  expense Expense?

  @@unique([refType, refId])
  @@index([periodId])
  @@index([entryDate])
  @@index([branchId])
  @@map("journal_entries")
}

/// บรรทัดรายการบัญชี — append-only (DB trigger กัน UPDATE/DELETE/TRUNCATE)
/// แต่ละบรรทัดเป็น debit หรือ credit อย่างใดอย่างหนึ่งเท่านั้น (CHECK ระดับ DB)
/// ผลรวม debit = credit ต่อ entry บังคับด้วย DEFERRABLE CONSTRAINT TRIGGER
model JournalLine {
  id           BigInt  @id @default(autoincrement())
  entryId      String  @map("entry_id")
  accountId    String  @map("account_id")
  debitSatang  BigInt  @default(0) @map("debit_satang")
  creditSatang BigInt  @default(0) @map("credit_satang")
  memo         String?

  createdAt DateTime @default(now()) @map("created_at")

  entry   JournalEntry @relation(fields: [entryId], references: [id])
  account Account      @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
  @@map("journal_lines")
}

/// ค่าใช้จ่ายทั่วไป — โพสต์ Dr บัญชีค่าใช้จ่ายที่เลือก / Cr เงินสด-ธนาคาร
model Expense {
  id             String   @id @default(uuid())
  docNo          String   @unique @map("doc_no")
  branchId       String   @map("branch_id")
  accountId      String   @map("account_id")
  amountSatang   BigInt   @map("amount_satang")
  description    String
  expenseDate    DateTime @map("expense_date")
  journalEntryId String?  @unique @map("journal_entry_id")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  branch       Branch        @relation(fields: [branchId], references: [id])
  account      Account       @relation(fields: [accountId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([branchId, expenseDate])
  @@map("expenses")
}

/// ค่าคอมมิชชั่นพนักงานต่อบิลขาย — คำนวณอัตโนมัติตอนขายสำเร็จ (rate configurable ผ่าน settings)
model Commission {
  id           String  @id @default(uuid())
  staffId      String  @map("staff_id")
  salesOrderId String  @unique @map("sales_order_id")
  periodId     String  @map("period_id")
  ratePercent  Decimal @map("rate_percent") @db.Decimal(5, 2)
  amountSatang BigInt  @map("amount_satang")

  createdAt DateTime @default(now()) @map("created_at")

  staff      User             @relation(fields: [staffId], references: [id])
  salesOrder SalesOrder       @relation(fields: [salesOrderId], references: [id])
  period     AccountingPeriod @relation(fields: [periodId], references: [id])

  @@index([staffId, createdAt])
  @@map("commissions")
}
